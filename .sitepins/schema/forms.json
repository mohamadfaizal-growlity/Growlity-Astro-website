{
  "file": "src/content/forms/{{slug}}.md",
  "name": "Forms",
  "fileType": "md",
  "fmType": "yaml",
  "template": [
    {
      "name": "title",
      "label": "Form Title",
      "type": "string",
      "value": "",
      "isIgnored": false,
      "defaultValue": ""
    },
    {
      "name": "sendToEmail",
      "label": "Send Submissions To (Email)",
      "type": "string",
      "value": "",
      "isIgnored": false,
      "defaultValue": "hello@growlity.com"
    },
    {
      "name": "fields",
      "label": "Form Fields",
      "type": "list",
      "value": [],
      "isIgnored": false,
      "defaultValue": [],
      "template": [
        {
          "name": "label",
          "label": "Field Label (e.g. First Name)",
          "type": "string",
          "value": "",
          "isIgnored": false,
          "defaultValue": ""
        },
        {
          "name": "type",
          "label": "Field Type",
          "type": "select",
          "value": "text",
          "isIgnored": false,
          "defaultValue": "text",
          "options": [
            {"label": "Short Text", "value": "text"},
            {"label": "Email Address", "value": "email"},
            {"label": "Phone Number", "value": "tel"},
            {"label": "Long Text (Paragraph)", "value": "textarea"},
            {"label": "Checkbox", "value": "checkbox"}
          ]
        },
        {
          "name": "required",
          "label": "Is this field required?",
          "type": "boolean",
          "value": true,
          "isIgnored": false,
          "defaultValue": true
        },
        {
          "name": "placeholder",
          "label": "Placeholder Text",
          "type": "string",
          "value": "",
          "isIgnored": false,
          "defaultValue": ""
        }
      ]
    },
    {
      "name": "submitButtonText",
      "label": "Submit Button Text",
      "type": "string",
      "value": "Submit",
      "isIgnored": false,
      "defaultValue": "Submit"
    },
    {
      "name": "successMessage",
      "label": "Success Message",
      "type": "string",
      "value": "Thank you! Your submission has been received.",
      "isIgnored": false,
      "defaultValue": "Thank you! Your submission has been received."
    }
  ]
}
