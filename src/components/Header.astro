---
---
<header class="bg-brand-light border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center">
        <!-- Logo -->
        <a href="/" class="text-2xl font-bold text-brand-green flex items-center gap-2">
          <svg class="w-8 h-8 text-brand-green" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
          </svg>
          Growlity
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        <a href="#" class="text-gray-600 hover:text-brand-green font-medium px-3 py-2 rounded-md transition-colors">Solutions</a>
        <a href="#" class="text-gray-600 hover:text-brand-green font-medium px-3 py-2 rounded-md transition-colors">Network</a>
        <a href="#" class="text-gray-600 hover:text-brand-green font-medium px-3 py-2 rounded-md transition-colors">Resources</a>
        <a href="#" class="text-gray-600 hover:text-brand-green font-medium px-3 py-2 rounded-md transition-colors">About Us</a>
      </nav>

      <!-- Action Buttons -->
      <div class="hidden md:flex items-center space-x-4">
        <a href="/admin" class="text-gray-600 hover:text-brand-green font-medium">Login</a>
        <a href="#" class="bg-brand-green hover:bg-green-800 text-white px-5 py-2.5 rounded-md font-medium transition-colors shadow-sm">
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button class="text-gray-600 hover:text-brand-green focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
