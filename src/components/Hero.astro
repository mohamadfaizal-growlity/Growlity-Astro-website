---
interface Props {
  heading: string;
  subheading?: string;
  primaryCta?: string;
  secondaryCta?: string;
}

const { 
  heading = "Business Sustainability Ratings", 
  subheading = "The world's most trusted business sustainability ratings. Join over 150,000 rated companies.",
  primaryCta = "Get Rated",
  secondaryCta = "Learn More"
} = Astro.props;
---
<section class="relative bg-brand-light-green overflow-hidden py-16 sm:py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left flex flex-col justify-center">
        <h1 class="text-4xl tracking-tight font-extrabold text-brand-dark sm:text-5xl md:text-6xl lg:text-5xl xl:text-6xl">
          <span class="block">{heading.split(' ').slice(0, -2).join(' ')}</span>
          <span class="block text-brand-green">{heading.split(' ').slice(-2).join(' ')}</span>
        </h1>
        <p class="mt-3 text-base text-gray-600 sm:mt-5 sm:text-xl lg:text-lg xl:text-xl">
          {subheading}
        </p>
        <div class="mt-8 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0">
          <div class="flex flex-col sm:flex-row gap-4 sm:justify-center lg:justify-start">
            <a href="#" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-brand-green hover:bg-green-800 md:py-4 md:text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
              {primaryCta}
            </a>
            <a href="#" class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-md text-brand-dark bg-white hover:bg-gray-50 md:py-4 md:text-lg transition-all shadow-sm">
              {secondaryCta}
            </a>
          </div>
        </div>
      </div>
      <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center">
        <div class="relative mx-auto w-full rounded-lg shadow-2xl lg:max-w-md overflow-hidden bg-white aspect-[4/3] flex items-center justify-center border border-gray-100">
           <!-- Placeholder for an image or graphic -->
           <div class="absolute inset-0 bg-gradient-to-br from-brand-green/20 to-brand-blue/20"></div>
           <svg class="w-32 h-32 text-brand-green opacity-50 z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
           </svg>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3">
    <div class="w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
  </div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3">
    <div class="w-96 h-96 bg-brand-green/10 rounded-full blur-3xl"></div>
  </div>
</section>
