---
interface Props {
  text?: string;
  link?: string;
  buttonText?: string;
  variant?: 'light' | 'dark' | 'outline';
}

const { 
  text, 
  link = "/contact",
  buttonText = "Contact Us",
  variant = 'light'
} = Astro.props;

let containerClass = "my-8 border rounded-xl p-8 text-center shadow-sm transition-all ";
let textClass = "text-2xl font-bold mb-2 mt-0 ";
let buttonClass = "inline-block px-8 py-3 rounded-md font-bold transition-colors no-underline ";

if (variant === 'dark') {
  containerClass += "bg-gray-900 border-gray-800";
  textClass += "text-white";
  buttonClass += "bg-brand-green text-white hover:bg-green-700";
} else if (variant === 'outline') {
  containerClass += "bg-transparent border-brand-green/30";
  textClass += "text-brand-green";
  buttonClass += "bg-brand-green text-white hover:bg-green-800";
} else {
  // light (default)
  containerClass += "bg-brand-light-green border-brand-green/20";
  textClass += "text-gray-900";
  buttonClass += "bg-brand-green text-white hover:bg-green-800";
}
---

<div class={containerClass}>
  <h3 class={textClass}>
    {text ? text : (Astro.slots.has('default') ? <slot /> : "Interested in learning more?")}
  </h3>
  <div class="mt-6">
    <a href={link} class={buttonClass}>
      {buttonText}
    </a>
  </div>
</div>
