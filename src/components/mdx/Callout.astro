---
interface Props {
  type?: 'info' | 'warning' | 'success' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const colorClasses = {
  info: 'bg-blue-50 border-blue-200 text-blue-800',
  warning: 'bg-yellow-50 border-yellow-200 text-yellow-800',
  success: 'bg-green-50 border-green-200 text-green-800',
  danger: 'bg-red-50 border-red-200 text-red-800',
};

const iconPaths = {
  info: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  warning: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  success: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  danger: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<div class={`my-6 p-4 rounded-lg border flex gap-4 items-start ${colorClasses[type]}`}>
  <svg class="w-6 h-6 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPaths[type]} />
  </svg>
  <div>
    {title && <h4 class="font-bold mb-1">{title}</h4>}
    <div class="text-sm prose-p:my-0">
      <slot />
    </div>
  </div>
</div>
