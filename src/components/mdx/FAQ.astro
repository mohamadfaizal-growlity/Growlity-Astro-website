<div class="w-full max-w-4xl mx-auto my-12 not-prose">
  <div class="text-center mb-10">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <p class="text-lg text-gray-600">Find answers to common questions about our services and expertise.</p>
  </div>

  <div class="space-y-4">
    <slot />
  </div>
</div>

<style>
  /* Smooth animation for the details element */
  :global(details > summary) {
    list-style: none;
  }
  :global(details[open] summary ~ *) {
    animation: slideDown 0.3s ease-in-out;
  }
  
  @keyframes slideDown {
    0% {
      opacity: 0;
      transform: translateY(-10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
