---
interface Props {
  q: string;
}

const { q } = Astro.props;
---

<details class="group bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden [&_summary::-webkit-details-marker]:hidden">
  <summary class="flex items-center justify-between p-6 cursor-pointer bg-white hover:bg-gray-50 transition-colors">
    <h3 class="text-lg font-medium text-gray-900 pr-4 m-0">
      {q}
    </h3>
    <span class="flex-shrink-0 ml-1.5 p-1.5 text-gray-900 bg-gray-100 rounded-full sm:p-3 group-open:bg-brand-green group-open:text-white transition-colors duration-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 transition duration-300 group-open:-rotate-45" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
      </svg>
    </span>
  </summary>
  
  <div class="p-6 pt-0 text-gray-600 leading-relaxed border-t border-gray-100 mt-2 bg-white prose-sm">
    <slot />
  </div>
</details>
