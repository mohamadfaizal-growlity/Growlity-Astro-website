---
import CTA from './CTA.astro';

interface Props {
  href?: string;
  [key: string]: any;
}

const { href, ...props } = Astro.props;
---

{href === '#CTA' ? (
  <CTA>
    <slot />
  </CTA>
) : (
  <a href={href} {...props} class="text-brand-green font-medium underline hover:text-green-800 transition-colors">
    <slot />
  </a>
)}
