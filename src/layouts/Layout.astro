---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import GlobalPopup from '../components/shared/GlobalPopup.astro';
import { Header } from '../components/theme/app/components/header';
import { Footer } from '../components/theme/app/components/footer';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Growlity - Business Sustainability Ratings" } = Astro.props;

// Fetch settings for Scripts
const settings = await getEntry('globalSettings', 'placeholder');
const { headerScripts, footerScripts } = settings?.data || {};

// Fetch GA ID from globalSettings if available (Fallback added for future)
const gaId = null;

// Fetch dynamic site settings (logo)
import { GET } from '../pages/api/sitepins/settings';
let siteLogo = "/growlity-logo.png";
try {
  const response = await GET();
  if (response && response.status === 200) {
     const settings = await response.json();
     if (settings.siteLogo) siteLogo = settings.siteLogo;
  }
} catch(e) {
  console.error("Failed to fetch settings for logo:", e);
}
---

<!doctype html>
<html lang="en" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
		
		{/* Custom Header Scripts (from Sitepins) */}
		{headerScripts && <Fragment set:html={headerScripts} />}
	</head>
	<body class="min-h-screen flex flex-col font-sans antialiased text-gray-900 bg-white selection:bg-[#0066FF]/20 selection:text-[#0066FF]">
		{/* READING PROGRESS BAR */}
		<div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-[#0066FF] to-[#00C853] z-[100] transition-all duration-150 ease-out origin-left" style="width: 0%;"></div>

		<Header client:load siteLogo={siteLogo} />
		
		<main class="flex-grow">
			<slot />
		</main>
		
		<Footer client:idle siteLogo={siteLogo} />
		
		<GlobalPopup />
		
		{/* Custom Footer Scripts (from Sitepins) */}
		{footerScripts && <Fragment set:html={footerScripts} />}

		<script>
			import Lenis from 'lenis';
			
			const lenis = new Lenis({
				autoRaf: true,
			});
		</script>
		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			function initOriginalAnimations() {
				// 1. AUTO-APPLY AOS ATTRIBUTES (Re-added for whole website effect)
				const revealElements = document.querySelectorAll('section, h1, h2, .card, footer');
				revealElements.forEach(el => {
					if (!el.hasAttribute('data-aos')) {
						el.setAttribute('data-aos', 'fade-up');
					}
				});

				// Initialize AOS Animation Library safely
				if (window.AOS) {
					window.AOS.init({
						duration: 800,   
						once: true,      
						offset: 50,      
					});
					window.AOS.refresh();
				}

				// Scroll Progress Bar Logic
				const progressBar = document.getElementById('scroll-progress');
				const updateProgress = () => {
					if (progressBar) {
						const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
						const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
						const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
						progressBar.style.width = scrolled + '%';
					}
				};
				window.addEventListener('scroll', updateProgress, { passive: true });
				updateProgress(); // init

				// Magnetic Buttons Logic
				const magneticElements = document.querySelectorAll('.magnetic-btn');
				magneticElements.forEach(btn => {
					btn.addEventListener('mousemove', (e) => {
						const rect = btn.getBoundingClientRect();
						const x = e.clientX - rect.left - rect.width / 2;
						const y = e.clientY - rect.top - rect.height / 2;
						// Move button slightly towards cursor
						btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
					});
					btn.addEventListener('mouseleave', () => {
						// Snap back to center
						btn.style.transform = 'translate(0px, 0px)';
					});
				});

				// 2. AUTO-DETECT NUMBERS & APPLY CLASSES (Re-added for whole website effect)
				const textElements = document.querySelectorAll('h1, h2, h3, h4, h5, h6, span, div, p, strong, b');
				textElements.forEach(el => {
					if (el.children.length === 0 && el.textContent) {
						const text = el.textContent.trim();
						const match = text.match(/^([$€£₹]?)(\d+(?:\.\d+)?)([+%KM]*)$/i);
						
						if (match) {
							const numVal = parseFloat(match[2]);
							if (numVal > 0 && !(numVal >= 1900 && numVal <= 2100 && match[2].length === 4 && match[3] === '')) {
								if (!el.classList.contains('stat-num-initialized')) {
									el.classList.add('stat-num');
									el.classList.add('stat-num-initialized');
									el.setAttribute('data-target', match[2]);
									if (match[1]) el.setAttribute('data-prefix', match[1]);
									if (match[3]) el.setAttribute('data-suffix', match[3]);
									// Start from 0
									el.innerText = match[1] + '0' + match[3];
								}
							}
						}
					}
				});

				// Number Counter Logic
				const stats = document.querySelectorAll('.stat-num');
				if (stats.length > 0) {
					const statsObserver = new IntersectionObserver((entries) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) { 
								const el = entry.target;
								const targetAttr = el.getAttribute('data-target'); 
								const prefix = el.getAttribute('data-prefix') || '';
								const suffix = el.getAttribute('data-suffix') || '';
								
								if (targetAttr) {
									const target = parseFloat(targetAttr);
									let count = 0;
									const duration = 2000; 
									const increment = target / (duration / 16); 
									
									const updateCount = () => {
										count += increment;
										if (count < target) {
											const currentVal = target % 1 === 0 ? Math.ceil(count).toString() : count.toFixed(1);
											el.innerText = prefix + currentVal + suffix;
											requestAnimationFrame(updateCount); 
										} else {
											el.innerText = prefix + target.toString() + suffix; 
										}
									};
									updateCount();
								}
								statsObserver.unobserve(el); 
							}
						});
					}, { threshold: 0.1 }); // Trigger sooner so we don't miss it
					stats.forEach(stat => statsObserver.observe(stat));
				}
			}

			// Run after full page load to prevent React Hydration errors
			const runInit = () => {
				setTimeout(initOriginalAnimations, 400); 
			};

			if (document.readyState === 'complete') {
				runInit();
			} else {
				window.addEventListener('load', runInit);
			}
			
			// For Astro view transitions
			document.addEventListener('astro:page-load', () => {
				setTimeout(initOriginalAnimations, 400);
			});
		</script>
	</body>
</html>
