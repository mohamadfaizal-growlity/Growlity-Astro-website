---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import GlobalPopup from '../components/shared/GlobalPopup.astro';
import { Header } from '../components/theme/app/components/header';
import { Footer } from '../components/theme/app/components/footer';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Growlity - Business Sustainability Ratings" } = Astro.props;

// Fetch settings for Scripts
const settings = await getEntry('globalSettings', 'placeholder');
const { headerScripts, footerScripts } = settings?.data || {};

// Fetch GA ID from globalSettings if available (Fallback added for future)
const gaId = null;

// Fetch dynamic site settings (logo)
import { GET } from '../pages/api/sitepins/settings';
let siteLogo = "/growlity-logo.png";
try {
  const response = await GET();
  if (response && response.status === 200) {
     const settings = await response.json();
     if (settings.siteLogo) siteLogo = settings.siteLogo;
  }
} catch(e) {
  console.error("Failed to fetch settings for logo:", e);
}
---

<!doctype html>
<html lang="en" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
		
		{/* Custom Header Scripts (from Sitepins) */}
		{headerScripts && <Fragment set:html={headerScripts} />}
	</head>
	<body class="min-h-screen flex flex-col font-sans antialiased text-gray-900 bg-white selection:bg-[#0066FF]/20 selection:text-[#0066FF]">
		{/* READING PROGRESS BAR */}
		<div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-[#0066FF] to-[#00C853] z-[100] transition-all duration-150 ease-out origin-left" style="width: 0%;"></div>

		<Header client:load siteLogo={siteLogo} />
		
		<main class="flex-grow">
			<slot />
		</main>
		
		<Footer client:idle siteLogo={siteLogo} />
		
		<GlobalPopup />
		
		{/* Custom Footer Scripts (from Sitepins) */}
		{footerScripts && <Fragment set:html={footerScripts} />}

		<script>
			import Lenis from 'lenis';
			
			const lenis = new Lenis({
				autoRaf: true,
			});
		</script>
		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			function initOriginalAnimations() {
				// Initialize AOS Animation Library
				if (window.AOS) {
					window.AOS.init({
						duration: 800,   
						once: true,      
						offset: 50,      
					});
				}

				// Scroll Progress Bar Logic
				const progressBar = document.getElementById('scroll-progress');
				const updateProgress = () => {
					if (progressBar) {
						const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
						const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
						const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
						progressBar.style.width = scrolled + '%';
					}
				};
				window.addEventListener('scroll', updateProgress, { passive: true });
				updateProgress(); // init

				// Magnetic Buttons Logic
				const magneticElements = document.querySelectorAll('.magnetic-btn');
				magneticElements.forEach(btn => {
					btn.addEventListener('mousemove', (e) => {
						const rect = btn.getBoundingClientRect();
						const x = e.clientX - rect.left - rect.width / 2;
						const y = e.clientY - rect.top - rect.height / 2;
						// Move button slightly towards cursor
						btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
					});
					btn.addEventListener('mouseleave', () => {
						// Snap back to center
						btn.style.transform = 'translate(0px, 0px)';
					});
				});

				// Number Counter Logic
				const stats = document.querySelectorAll('.stat-num');
				if (stats.length > 0) {
					const statsObserver = new IntersectionObserver((entries) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) { // Checks if the number is visible on screen
								const el = entry.target;
								const targetAttr = el.getAttribute('data-target'); // Gets the final number
								if (targetAttr) {
									const target = parseFloat(targetAttr);
									let count = 0;
									const duration = 2000; // The animation lasts exactly 2 seconds
									const increment = target / (duration / 16); // Calculates step for ~60fps
									
									const updateCount = () => {
										count += increment;
										if (count < target) {
											// Updates the text, keeping decimals if needed
											el.innerText = target % 1 === 0 ? Math.ceil(count).toString() : count.toFixed(1);
											requestAnimationFrame(updateCount); // Loops until finished smoothly
										} else {
											el.innerText = target.toString(); // Ensures exact final number
										}
									};
									updateCount();
								}
								statsObserver.unobserve(el); // Stops observing once the animation has run
							}
						});
					}, { threshold: 0.5 }); // Triggers when 50% of the number is visible
					stats.forEach(stat => statsObserver.observe(stat));
				}
			}

			// Run on initial load and Astro View Transitions
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initOriginalAnimations);
			} else {
				initOriginalAnimations();
			}
			document.addEventListener('astro:page-load', initOriginalAnimations);
		</script>
	</body>
</html>
