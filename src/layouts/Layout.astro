---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import GlobalPopup from '../components/shared/GlobalPopup.astro';
import { Header } from '../components/theme/app/components/header';
import { Footer } from '../components/theme/app/components/footer';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Growlity - Business Sustainability Ratings" } = Astro.props;

// Fetch settings for Scripts
const settings = await getEntry('globalSettings', 'placeholder');
const { headerScripts, footerScripts } = settings?.data || {};

// Fetch GA ID from globalSettings if available (Fallback added for future)
const gaId = null;

// Fetch dynamic site settings (logo)
import { GET } from '../pages/api/sitepins/settings';
let siteLogo = "/growlity-logo.png";
try {
  const response = await GET();
  if (response && response.status === 200) {
     const settings = await response.json();
     if (settings.siteLogo) siteLogo = settings.siteLogo;
  }
} catch(e) {
  console.error("Failed to fetch settings for logo:", e);
}
---

<!doctype html>
<html lang="en" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
		
		{/* Custom Header Scripts (from Sitepins) */}
		{headerScripts && <Fragment set:html={headerScripts} />}
	</head>
	<body class="bg-background text-foreground font-sans flex flex-col min-h-screen">
		<Header client:load siteLogo={siteLogo} />
		
		<main class="flex-grow">
			<slot />
		</main>
		
		<Footer client:idle siteLogo={siteLogo} />
		
		<GlobalPopup />
		
		{/* Custom Footer Scripts (from Sitepins) */}
		{footerScripts && <Fragment set:html={footerScripts} />}

		<script>
			import Lenis from 'lenis';
			
			const lenis = new Lenis({
				autoRaf: true,
			});
		</script>
		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			function initAnimations() {
				// Auto-apply AOS to major elements across the site
				const elementsToAnimate = document.querySelectorAll('main section, main h1, main h2, main h3, main img, main .card, main .grid > div, footer');
				elementsToAnimate.forEach((el) => {
					if (!el.hasAttribute('data-aos')) {
						el.setAttribute('data-aos', 'fade-up');
					}
				});

				// Initialize AOS Animation Library
				if (window.AOS) {
					window.AOS.init({
						duration: 800,
						once: true,
						offset: 50,
					});
					window.AOS.refresh();
				}

				// Auto-detect numbers to animate (elements containing only numbers with optional +, %, $, etc.)
				const textElements = document.querySelectorAll('h1, h2, h3, h4, h5, h6, span, div, p, strong, b');
				textElements.forEach(el => {
					if (el.childNodes.length === 1 && el.childNodes[0].nodeType === Node.TEXT_NODE) {
						const text = el.textContent.trim();
						// Matches patterns like "100", "500+", "99.9%", "10K", "$100", "20.5M"
						const match = text.match(/^([$€£₹]?)(\d+(?:\.\d+)?)([+%KM]*)$/i);
						if (match) {
							const numVal = parseFloat(match[2]);
							// Don't animate years like "2024" or standard body text if it's not a stat
							if (!(numVal >= 1900 && numVal <= 2100 && match[2].length === 4 && match[3] === '')) {
								if (!el.classList.contains('stat-num')) {
									el.classList.add('stat-num');
									el.setAttribute('data-target', match[2]);
									el.setAttribute('data-prefix', match[1]);
									el.setAttribute('data-suffix', match[3]);
									// Set initial text to 0 to prepare for animation
									el.innerText = match[1] + '0' + match[3];
								}
							}
						}
					}
				});

				// Number Counter Logic
				const stats = document.querySelectorAll('.stat-num');
				if (stats.length > 0) {
					const statsObserver = new IntersectionObserver((entries) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) {
								const el = entry.target;
								const targetAttr = el.getAttribute('data-target') || el.textContent.replace(/[^0-9.]/g, '');
								const prefix = el.getAttribute('data-prefix') || '';
								const suffix = el.getAttribute('data-suffix') || '';
								
								if (targetAttr) {
									const target = parseFloat(targetAttr);
									let count = 0;
									const duration = 2000;
									const increment = target / (duration / 16);
									
									const updateCount = () => {
										count += increment;
										if (count < target) {
											const currentVal = target % 1 === 0 ? Math.ceil(count).toString() : count.toFixed(1);
											el.innerText = prefix + currentVal + suffix;
											requestAnimationFrame(updateCount);
										} else {
											el.innerText = prefix + target.toString() + suffix;
										}
									};
									updateCount();
								}
								statsObserver.unobserve(el);
							}
						});
					}, { threshold: 0.1 });
					stats.forEach(stat => statsObserver.observe(stat));
				}
			}

			// Run when DOM is ready
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initAnimations);
			} else {
				initAnimations();
			}
			// Re-run for Astro view transitions
			document.addEventListener('astro:page-load', initAnimations);
		</script>
	</body>
</html>
