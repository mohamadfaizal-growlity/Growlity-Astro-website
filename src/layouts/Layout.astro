---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import GlobalPopup from '../components/shared/GlobalPopup.astro';
import { Header } from '../components/theme/app/components/header';
import { Footer } from '../components/theme/app/components/footer';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Growlity - Business Sustainability Ratings" } = Astro.props;

// Fetch settings for Scripts
const settings = await getEntry('globalSettings', 'placeholder');
const { headerScripts, footerScripts } = settings?.data || {};

// Fetch GA ID from globalSettings if available (Fallback added for future)
const gaId = null;

// Fetch dynamic site settings (logo)
import { GET } from '../pages/api/sitepins/settings';
let siteLogo = "/growlity-logo.png";
try {
  const response = await GET();
  if (response && response.status === 200) {
     const settings = await response.json();
     if (settings.siteLogo) siteLogo = settings.siteLogo;
  }
} catch(e) {
  console.error("Failed to fetch settings for logo:", e);
}
---

<!doctype html>
<html lang="en" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
		
		{/* Custom Header Scripts (from Sitepins) */}
		{headerScripts && <Fragment set:html={headerScripts} />}
	</head>
	<body class="bg-background text-foreground font-sans flex flex-col min-h-screen">
		<Header client:load siteLogo={siteLogo} />
		
		<main class="flex-grow">
			<slot />
		</main>
		
		<Footer client:idle siteLogo={siteLogo} />
		
		<GlobalPopup />
		
		{/* Custom Footer Scripts (from Sitepins) */}
		{footerScripts && <Fragment set:html={footerScripts} />}

		<script>
			import Lenis from 'lenis';
			
			const lenis = new Lenis({
				autoRaf: true,
			});
		</script>
		<script is:inline>
			function initAnimations() {
				console.log("đźš€ Growlity Animations Initializing...");

				// 1. SCROLL REVEAL LOGIC (Replaces AOS)
				const revealElements = document.querySelectorAll('section, h1, h2, .card, footer');
				console.log(`Found ${revealElements.length} elements for scroll reveal.`);
				
				const revealObserver = new IntersectionObserver((entries, observer) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-revealed');
							observer.unobserve(entry.target); 
						}
					});
				}, { rootMargin: "0px 0px -50px 0px", threshold: 0 });

				revealElements.forEach(el => {
					if (!el.classList.contains('reveal-on-scroll') && !el.classList.contains('is-revealed')) {
						el.classList.add('reveal-on-scroll');
						revealObserver.observe(el);
					}
				});

				// 2. AUTO-DETECT NUMBERS & COUNTER LOGIC
				const textElements = document.querySelectorAll('h1, h2, h3, h4, h5, h6, span, div, p, strong, b');
				let statCount = 0;
				
				const statsObserver = new IntersectionObserver((entries, observer) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							const el = entry.target;
							const targetAttr = el.getAttribute('data-target');
							const prefix = el.getAttribute('data-prefix') || '';
							const suffix = el.getAttribute('data-suffix') || '';
							
							if (targetAttr) {
								const target = parseFloat(targetAttr);
								let count = 0;
								const duration = 2000; 
								const increment = target / (duration / 16);
								
								const updateCount = () => {
									count += increment;
									if (count < target) {
										const currentVal = target % 1 === 0 ? Math.ceil(count).toString() : count.toFixed(1);
										el.innerText = prefix + currentVal + suffix;
										requestAnimationFrame(updateCount);
									} else {
										el.innerText = prefix + target.toString() + suffix;
									}
								};
								updateCount();
							}
							observer.unobserve(el);
						}
					});
				}, { threshold: 0.1 });

				textElements.forEach(el => {
					// Use children.length === 0 to ensure no nested HTML tags, 
					// but allow multiple text nodes (which React sometimes creates)
					if (el.children.length === 0 && el.textContent) {
						const text = el.textContent.trim();
						const match = text.match(/^([$â‚¬ÂŁâ‚ą]?)(\d+(?:\.\d+)?)([+%KM]*)$/i);
						
						if (match) {
							const numVal = parseFloat(match[2]);
							if (numVal > 0 && !(numVal >= 1900 && numVal <= 2100 && match[2].length === 4 && match[3] === '')) {
								if (!el.classList.contains('stat-num-initialized')) {
									el.classList.add('stat-num-initialized');
									el.setAttribute('data-target', match[2]);
									el.setAttribute('data-prefix', match[1]);
									el.setAttribute('data-suffix', match[3]);
									el.innerText = match[1] + '0' + match[3];
									statsObserver.observe(el);
									statCount++;
								}
							}
						}
					}
				});
				console.log(`Found ${statCount} number counters.`);
			}

			// Wait for FULL page load (including React hydration) to avoid Hydration Mismatch errors
			const runInit = () => {
				setTimeout(initAnimations, 300); 
			};

			if (document.readyState === 'complete') {
				runInit();
			} else {
				window.addEventListener('load', runInit);
			}
			
			// For Astro view transitions
			document.addEventListener('astro:page-load', () => {
				// Re-run on soft navigations
				setTimeout(initAnimations, 300);
			});
		</script>
	</body>
</html>
