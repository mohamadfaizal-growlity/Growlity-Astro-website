---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import GlobalPopup from '../components/shared/GlobalPopup.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Fetch settings for Scripts
const settings = await getEntry('globalSettings', 'placeholder');
const { headerScripts, footerScripts } = settings?.data || {};

// Fetch GA ID from globalSettings if available (Fallback added for future)
const gaId = null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Growlity - Business Sustainability Ratings" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
		
		{/* Custom Header Scripts (from Sitepins) */}
		{headerScripts && <Fragment set:html={headerScripts} />}
	</head>
	<body class="bg-brand-light text-brand-dark font-sans flex flex-col min-h-screen">
		<slot />
		
		<GlobalPopup />
		
		{/* Custom Footer Scripts (from Sitepins) */}
		{footerScripts && <Fragment set:html={footerScripts} />}
	</body>
</html>
