---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Fetch GA ID from seoDefaults if available
const seoSettings = await getCollection('seoDefaults');
const gaId = seoSettings.length > 0 ? seoSettings[0].data.googleAnalyticsId : null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Growlity - Business Sustainability Ratings" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		{/* Google Analytics */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', gaId);
				</script>
			</>
		)}
	</head>
	<body class="bg-brand-light text-brand-dark font-sans flex flex-col min-h-screen">
		<slot />
	</body>
</html>
