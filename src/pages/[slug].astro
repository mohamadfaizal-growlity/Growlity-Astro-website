---
export const prerender = true;
import { getCollection, render } from "astro:content";
import FAQAccordion from "../components/shared/FAQAccordion.astro";
import Callout from "../components/mdx/Callout.astro";
import YouTube from "../components/mdx/YouTube.astro";
import FAQ from "../components/mdx/FAQ.astro";
import FAQItem from "../components/mdx/FAQItem.astro";
import CTA from "../components/mdx/CTA.astro";
import MarkdownLink from "../components/mdx/MarkdownLink.astro";
import DynamicRenderer from "../components/shared/DynamicRenderer.astro";
import Layout from "../layouts/Layout.astro";

// This function tells Astro to create a page for every file in the "pages" collection
export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Layout
  title={page.data.seoSettings?.title || page.data.title}
  description={page.data.seoSettings?.description || page.data.heroSection?.description || ""}
>
  <!-- Page Header / Hero -->
  <header class="bg-brand-light-green py-20 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-green mb-4">
      {page.data.heroSection?.title || page.data.title}
    </h1>
    {
      page.data.heroSection?.description && (
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          {page.data.heroSection?.description}
        </p>
      )
    }
  </header>

  <!-- Main Content from Sitepins -->
  <main class="max-w-4xl mx-auto py-12 px-6 prose prose-lg prose-green">
    <!-- This renders the standard markdown content -->
    <Content components={{ Callout, YouTube, CTA, FAQ, FAQItem, a: MarkdownLink }} />
  </main>

    <!-- Visual Builder Dynamic Blocks removed -->

  <!-- Static Fields Section -->
  <section class="w-full">
    {/* BANNER IMAGE BLOCK */}
    {
      page.data.bannerSection?.image && (
        <div class="w-full my-12 relative overflow-hidden group border-y border-gray-100">
          <div class="w-full aspect-[4/3] md:aspect-video max-h-[600px] overflow-hidden bg-gray-100 flex items-center justify-center">
            <img
              src={page.data.bannerSection.image}
              alt={page.data.bannerSection.caption || "Featured Banner"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          {page.data.bannerSection.caption && (
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent p-8 pt-24">
              <p class="text-white text-xl md:text-3xl font-bold max-w-4xl mx-auto text-center drop-shadow-md">
                {page.data.bannerSection.caption}
              </p>
            </div>
          )}
        </div>
      )
    }

    {/* BOTTOM TEXT BLOCK */}
    {
      page.data.bottomSection?.text && (
        <div class="max-w-4xl mx-auto py-8 px-6 prose prose-lg prose-green text-center">
          <h2 class="text-2xl font-bold text-gray-900">
            {page.data.bottomSection.text}
          </h2>
        </div>
      )
    }

    

    
  </section>
</Layout>
