---
import { getCollection } from 'astro:content';
import FAQAccordion from '../components/shared/FAQAccordion.astro';

// This function tells Astro to create a page for every file in the "pages" collection
export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map(page => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.data.seoTitle || page.data.title}</title>
    <meta name="description" content={page.data.seoDescription || page.data.heroDescription || ''} />
  </head>
  <body class="bg-white text-gray-900">
    
    <!-- Page Header / Hero -->
    <header class="bg-brand-light-green py-20 px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-green mb-4">
        {page.data.heroTitle || page.data.title}
      </h1>
      {page.data.heroDescription && (
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">{page.data.heroDescription}</p>
      )}
    </header>

    <!-- Main Content from Sitepins -->
    <main class="max-w-4xl mx-auto py-12 px-6 prose prose-lg prose-green">
      <!-- This renders the standard markdown content -->
      {page.body && <div>{page.body}</div>}
    </main>

    <!-- Static Fields Section -->
    <section class="w-full">
      
      {/* BANNER IMAGE BLOCK */}
      {page.data.bannerImage && (
        <div class="w-full my-12 relative overflow-hidden group border-y border-gray-100">
          <div class="w-full aspect-[4/3] md:aspect-video max-h-[600px] overflow-hidden bg-gray-100 flex items-center justify-center">
            <img src={page.data.bannerImage} alt={page.data.bannerCaption || "Featured Banner"} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          {page.data.bannerCaption && (
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent p-8 pt-24">
              <p class="text-white text-xl md:text-3xl font-bold max-w-4xl mx-auto text-center drop-shadow-md">{page.data.bannerCaption}</p>
            </div>
          )}
        </div>
      )}

      {/* BOTTOM TEXT BLOCK */}
      {page.data.bottomText && (
        <div class="max-w-4xl mx-auto py-8 px-6 prose prose-lg prose-green text-center">
          <h2 class="text-2xl font-bold text-gray-900">{page.data.bottomText}</h2>
        </div>
      )}

      {/* FAQ BLOCK */}
      {page.data.faqList && page.data.faqList.length > 0 && (
        <div class="bg-gray-50 py-16 px-6 mt-8 mb-8 border-y border-gray-200">
          <FAQAccordion faqList={page.data.faqList} />
        </div>
      )}

      {/* CTA BLOCK */}
      {page.data.ctaReference && (
        <div class="bg-brand-green text-white py-16 px-6 text-center my-8">
          <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
          <p class="text-xl mb-8">Contact us about {page.data.ctaReference}</p>
          <a href="/contact" class="bg-white text-brand-green px-8 py-3 rounded font-bold hover:bg-gray-100 transition-colors">
            Contact Us
          </a>
        </div>
      )}
      
    </section>

  </body>
</html>
