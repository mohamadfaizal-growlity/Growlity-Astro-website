---
import { getCollection } from 'astro:content';
import FAQAccordion from '../components/shared/FAQAccordion.astro';

// This function tells Astro to create a page for every file in the "pages" collection
export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map(page => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.data.seoTitle || page.data.title}</title>
    <meta name="description" content={page.data.seoDescription || page.data.heroDescription || ''} />
  </head>
  <body class="bg-white text-gray-900">
    
    <!-- Page Header / Hero -->
    <header class="bg-brand-light-green py-20 px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-green mb-4">
        {page.data.heroTitle || page.data.title}
      </h1>
      {page.data.heroDescription && (
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">{page.data.heroDescription}</p>
      )}
    </header>

    <!-- Main Content from Sitepins -->
    <main class="max-w-4xl mx-auto py-12 px-6 prose prose-lg prose-green">
      <!-- This renders the standard markdown content -->
      {page.body && <div>{page.body}</div>}
    </main>

    <!-- ACF-Like Dynamic Page Builder Blocks -->
    {page.data.pageBlocks && page.data.pageBlocks.map((block) => (
      <section class="w-full">
        
        {/* TEXT BLOCK */}
        {block.blockType === 'Text Content' && block.textContent && (
          <div class="max-w-4xl mx-auto py-8 px-6 prose prose-lg prose-green">
            <p>{block.textContent}</p>
          </div>
        )}

        {/* FAQ BLOCK */}
        {block.blockType === 'FAQ Section' && block.faqList && (
          <div class="bg-gray-50 py-16 px-6 mt-8 mb-8 border-y border-gray-200">
            <FAQAccordion faqList={block.faqList} />
          </div>
        )}

        {/* CTA BLOCK */}
        {block.blockType === 'CTA Section' && block.ctaReference && (
          <div class="bg-brand-green text-white py-16 px-6 text-center my-8">
            <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
            <p class="text-xl mb-8">Contact us about {block.ctaReference}</p>
            <a href="/contact" class="bg-white text-brand-green px-8 py-3 rounded font-bold hover:bg-gray-100 transition-colors">
              Contact Us
            </a>
          </div>
        )}

      </section>
    ))}

  </body>
</html>
