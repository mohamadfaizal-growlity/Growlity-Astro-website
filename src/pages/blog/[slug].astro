---
import { getCollection, render } from 'astro:content';
import FAQAccordion from '../../components/shared/FAQAccordion.astro';

// This function tells Astro to create a page for every file in the "blog" collection
export async function getStaticPaths() {
  const blogs = await getCollection('blog');
  return blogs.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.seoTitle || post.data.title}</title>
    <meta name="description" content={post.data.seoDescription || post.data.excerpt || ''} />
  </head>
  <body class="bg-white text-gray-900">
    
    <!-- Blog Header -->
    <header class="bg-brand-light-green py-20 px-6 text-center border-b border-gray-200">
      <div class="max-w-4xl mx-auto">
        <span class="text-sm font-bold text-brand-green uppercase tracking-wider">{post.data.category}</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4 mb-6">
          {post.data.title}
        </h1>
        <div class="flex items-center justify-center space-x-4 text-gray-600">
          <span>By {post.data.author}</span>
          <span>•</span>
          <span>{new Date(post.data.publishedDate).toLocaleDateString()}</span>
        </div>
      </div>
    </header>

    <!-- Main Content from Sitepins -->
    <main class="max-w-4xl mx-auto py-12 px-6 prose prose-lg prose-green">
      <!-- This renders the rich text content -->
      <Content />
    </main>

    <!-- ACF-Like Dynamic Page Builder Blocks -->
    {post.data.pageBlocks && post.data.pageBlocks.map((block) => (
      <section class="w-full">
        
        {/* TEXT BLOCK */}
        {block.blockType === 'Text Content' && block.textContent && (
          <div class="max-w-4xl mx-auto py-8 px-6 prose prose-lg prose-green text-center">
            <h2 class="text-2xl font-bold text-gray-900">{block.textContent}</h2>
          </div>
        )}

        {/* FAQ BLOCK */}
        {block.blockType === 'FAQ Section' && block.faqList && (
          <div class="bg-gray-50 py-16 px-6 mt-8 mb-8 border-y border-gray-200">
            <FAQAccordion faqList={block.faqList} />
          </div>
        )}

        {/* CTA BLOCK */}
        {block.blockType === 'CTA Section' && block.ctaReference && (
          <div class="bg-brand-green text-white py-16 px-6 text-center my-8">
            <h2 class="text-3xl font-bold mb-4">Interested in learning more?</h2>
            <p class="text-xl mb-8">Let's discuss {block.ctaReference}</p>
            <a href="/contact" class="bg-white text-brand-green px-8 py-3 rounded font-bold hover:bg-gray-100 transition-colors inline-block">
              Contact Us
            </a>
          </div>
        )}

      </section>
    ))}

  </body>
</html>
