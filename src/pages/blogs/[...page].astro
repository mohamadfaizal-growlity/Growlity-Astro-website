---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ArrowRight } from 'lucide-react';

export async function getStaticPaths({ paginate }: any) {
  const allBlogs = await getCollection('blogs', (post) => {
    return !post.data.draft && post.data.publishedDate <= new Date();
  });

  // Sort by date (newest first)
  allBlogs.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());

  return paginate(allBlogs, { pageSize: 12 });
}

const { page } = Astro.props as any;
---

<Layout title={`Blog | Growlity ${page.currentPage > 1 ? `| Page ${page.currentPage}` : ''}`}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Our Blog</h1>
      <p class="text-xl text-gray-600">Latest insights, news, and articles</p>
    </div>

    <div class="flex items-center justify-between mb-8">
      <button class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors shadow-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        Filter
      </button>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {page.data.map((post: any) => (
        <a href={`/blog/${post.id}`} class="block group">
          <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all h-full flex flex-col">
            {post.data.featuredImage ? (
              <img 
                src={post.data.featuredImage} 
                alt={post.data.title} 
                class="w-full aspect-video object-cover"
              />
            ) : (
              <div class="w-full aspect-video bg-green-50 flex items-center justify-center text-green-200">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
                </svg>
              </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center text-sm text-gray-500 mb-3">
                <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full font-medium text-xs">
                  {post.data.category}
                </span>
                <span class="mx-2">•</span>
                <time datetime={post.data.publishedDate.toISOString()}>
                  {post.data.publishedDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="text-xl font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-2">
                {post.data.title}
              </h2>
              {post.data.excerpt && (
                <p class="text-gray-600 line-clamp-3 mt-auto">
                  {post.data.excerpt}
                </p>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>

    {/* PAGINATION CONTROLS */}
    {page.lastPage > 1 && (
      <div class="mt-16 flex items-center justify-center gap-2">
        {page.url.prev ? (
          <a href={page.url.prev} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </span>
        )}
        
        <div class="flex items-center gap-1 mx-4">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
            <a 
              href={pageNum === 1 ? '/blogs' : `/blogs/${pageNum}`}
              class={`w-10 h-10 flex items-center justify-center rounded-lg font-medium transition-colors ${
                pageNum === page.currentPage 
                  ? 'bg-[#0066FF] text-white shadow-md' 
                  : 'text-slate-600 hover:bg-slate-100'
              }`}
            >
              {pageNum}
            </a>
          ))}
        </div>

        {page.url.next ? (
          <a href={page.url.next} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </span>
        )}
      </div>
    )}
  </main>
</Layout>
