---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Callout from '../../components/mdx/Callout.astro';
import YouTube from '../../components/mdx/YouTube.astro';
import FAQ from "../../components/mdx/FAQ.astro";
import FAQItem from "../../components/mdx/FAQItem.astro";
import CTA from '../../components/mdx/CTA.astro';
import MarkdownLink from '../../components/mdx/MarkdownLink.astro';
import Comments from '../../components/shared/Comments.astro';
import FAQAccordion from '../../components/shared/FAQAccordion.astro';
import '../../styles/global.css';

// This function tells Astro to create a page for every file in the "blog" collection
export async function getStaticPaths() {
  const blogs = await getCollection('blogs');
  return blogs.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fetch settings
const gaId = null;

const globalSettings = await getCollection('globalSettings');
const disqusShortname = globalSettings.length > 0 ? globalSettings[0].data.disqusShortname : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.seoSettings?.title || post.data.title}</title>
    <meta name="description" content={post.data.seoSettings?.description || post.data.excerpt || ''} />

    {/* Google Analytics */}
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-white text-gray-900">
    
    <!-- Blog Header -->
    <header class="bg-brand-light-green py-10 px-6 text-center border-b border-gray-200">
      <div class="max-w-4xl mx-auto">
        <span class="text-sm font-bold text-brand-green uppercase tracking-wider">{post.data.category}</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-4 mb-6">
          {post.data.title}
        </h1>
        <div class="flex items-center justify-center space-x-4 text-gray-600">
          <span>By {post.data.author}</span>
          <span>•</span>
          <span>{new Date(post.data.publishedDate).toLocaleDateString()}</span>
        </div>
      </div>
    </header>

    <!-- Main Featured Image (Shows at the top) -->
    {post.data.featuredImage && (
      <div class="w-full max-w-5xl mx-auto mt-8 px-6">
        <div class="w-full aspect-[4/3] md:aspect-video max-h-[600px] overflow-hidden rounded-2xl shadow-lg bg-gray-100">
          <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-full object-cover" />
        </div>
      </div>
    )}

    <!-- Main Content from Sitepins -->
    <main class="max-w-4xl mx-auto py-12 px-6 prose prose-lg prose-green">
      <!-- This renders the rich text content -->
      <Content components={{ Callout, YouTube, CTA, FAQ, FAQItem, a: MarkdownLink }} />
    </main>

    <!-- Static Fields Section -->
    <section class="w-full">
      
      {/* BANNER IMAGE BLOCK */}
      {post.data.bannerSection?.image && (
        <div class="w-full my-12 relative overflow-hidden group border-y border-gray-100">
          <div class="w-full aspect-[4/3] md:aspect-video max-h-[600px] overflow-hidden bg-gray-100 flex items-center justify-center">
            <img src={post.data.bannerSection.image} alt={post.data.bannerSection.caption || "Featured Banner"} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          {post.data.bannerSection.caption && (
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent p-8 pt-12">
              <p class="text-white text-xl md:text-3xl font-bold max-w-4xl mx-auto text-center drop-shadow-md">{post.data.bannerSection.caption}</p>
            </div>
          )}
        </div>
      )}

      {/* BOTTOM TEXT BLOCK */}
      {post.data.bottomSection?.text && (
        <div class="max-w-4xl mx-auto py-8 px-6 prose prose-lg prose-green text-center">
          <h2 class="text-2xl font-bold text-gray-900">{post.data.bottomSection.text}</h2>
        </div>
      )}

      

      
    </section>

    {/* Disqus Comments */}
    {disqusShortname && (
      <Comments 
        shortname={disqusShortname} 
        url={`https://growlity-astro-website.vercel.app/blog/${post.id}`}
        identifier={post.id}
      />
    )}

  </body>
</html>
