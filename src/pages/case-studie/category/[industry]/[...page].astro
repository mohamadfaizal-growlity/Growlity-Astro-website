---
export const prerender = true;
import Layout from '../../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ArrowRight, ArrowRight as ArrowIcon } from 'lucide-react';

export async function getStaticPaths({ paginate }: any) {
  let allCases = await getCollection('caseStudies');
  
  // Case Studies don't have a date field by default, so we reverse them 
  // to show the latest added ones first
  allCases = allCases.reverse();

  // Get unique industries
  const uniqueIndustries = [...new Set(allCases.map((post) => post.data.industry).filter(Boolean))];

  // Return paths for each industry
  return uniqueIndustries.flatMap((industry) => {
    const industryLower = industry.toLowerCase().replace(/\s+/g, '-');
    const filteredCases = allCases.filter((post) => post.data.industry === industry);
    
    return paginate(filteredCases, {
      params: { industry: industryLower },
      props: { uniqueIndustries, currentIndustry: industry },
      pageSize: 12,
    });
  });
}

const { page, uniqueIndustries, currentIndustry } = Astro.props as any;
---

<Layout title={`${currentIndustry} | Growlity ${page.currentPage > 1 ? `| Page ${page.currentPage}` : ''}`}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 tracking-tight">Case Studies</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Discover how we help global organizations achieve their sustainability goals.</p>
    </div>

    <div class="mb-10">
      <div class="flex overflow-x-auto pb-4 mb-2 sm:pb-0 sm:mb-6 sm:flex-wrap gap-3 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
        <a href="/case-studie" class="px-6 py-2 rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 font-medium text-sm transition-colors whitespace-nowrap shrink-0">All articles</a>
        {uniqueIndustries.map((industry: string) => {
          const isActive = industry === currentIndustry;
          return (
            <a 
              href={`/case-studie/category/${industry.toLowerCase().replace(/\s+/g, '-')}`} 
              class={`px-6 py-2 rounded-full font-medium text-sm transition-colors whitespace-nowrap shrink-0 ${isActive ? 'bg-[#0066FF] text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}
            >
              {industry}
            </a>
          );
        })}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {page.data.map((study: any) => (
        <a href={`/case-studie/${study.id}`} class="block group">
          <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all duration-300 h-full flex flex-col relative">
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-brand-green text-xs font-bold px-3 py-1.5 rounded-full z-10 shadow-sm">
              {study.data.industry}
            </div>
            
            <div class="aspect-video w-full relative overflow-hidden bg-slate-50">
              {study.data.featuredImage || study.data.thumbnail ? (
                <img 
                  src={study.data.featuredImage || study.data.thumbnail} 
                  alt={study.data.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-brand-green/20 bg-gradient-to-br from-green-50 to-emerald-50">
                  <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>
              )}
            </div>
            
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-xl font-bold text-gray-900 group-hover:text-brand-green transition-colors mb-3 leading-snug">
                {study.data.title}
              </h3>
              
              <div class="mt-auto flex items-center justify-between pt-5 border-t border-gray-100">
                <span class="text-sm font-semibold text-gray-500">{study.data.clientName}</span>
                <span class="text-brand-green flex items-center text-sm font-bold group-hover:translate-x-1 transition-transform">
                  Read Case Study <ArrowIcon className="w-4 h-4 ml-1" />
                </span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>

    {/* PAGINATION CONTROLS */}
    {page.lastPage > 1 && (
      <div class="mt-16 flex items-center justify-center gap-2">
        {page.url.prev ? (
          <a href={page.url.prev} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </span>
        )}
        
        <div class="flex items-center gap-1 mx-4">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
            <a 
              href={pageNum === 1 ? `/case-studie/category/${currentIndustry.toLowerCase().replace(/\s+/g, '-')}` : `/case-studie/category/${currentIndustry.toLowerCase().replace(/\s+/g, '-')}/${pageNum}`}
              class={`w-10 h-10 flex items-center justify-center rounded-lg font-medium transition-colors ${
                pageNum === page.currentPage 
                  ? 'bg-[#0066FF] text-white shadow-md' 
                  : 'text-slate-600 hover:bg-slate-100'
              }`}
            >
              {pageNum}
            </a>
          ))}
        </div>

        {page.url.next ? (
          <a href={page.url.next} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </span>
        )}
      </div>
    )}
  </main>
</Layout>
