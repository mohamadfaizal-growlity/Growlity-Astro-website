---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = await getCollection('caseStudies');

---

<Layout title="Case Studies | Growlity">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Case Studies</h1>
      <p class="text-xl text-gray-600">See how we've helped our clients succeed</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allCaseStudies.map((study) => (
        <a href={`/case-studies/${study.id}`} class="block group">
          <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all h-full flex flex-col">
            {study.data.thumbnail ? (
              <img 
                src={study.data.thumbnail} 
                alt={study.data.clientName} 
                class="w-full h-48 object-cover"
              />
            ) : (
              <div class="w-full h-48 bg-blue-50 flex items-center justify-center text-blue-200">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
                </svg>
              </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center text-sm text-gray-500 mb-3">
                <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full font-medium text-xs">
                  {study.data.industry}
                </span>
              </div>
              <h2 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-2">
                {study.data.clientName}
              </h2>
              {study.data.challenge && (
                <p class="text-gray-600 line-clamp-3 mt-auto">
                  {study.data.challenge}
                </p>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>
</Layout>
