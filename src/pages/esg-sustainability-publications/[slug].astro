---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Callout from '../../components/mdx/Callout.astro';
import YouTube from '../../components/mdx/YouTube.astro';
import CTA from '../../components/mdx/CTA.astro';
import MarkdownLink from '../../components/mdx/MarkdownLink.astro';

export async function getStaticPaths() {
  const publications = await getCollection('publications');
  return publications.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.seoTitle || post.data.title} | Growlity`}>
  <div class="bg-slate-50 min-h-screen pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header Section -->
      <div class="bg-white rounded-3xl p-8 md:p-12 shadow-[0_8px_30px_rgb(0,102,255,0.08)] border border-slate-100 mb-12 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-[#0066FF] to-[#00C853]"></div>
        
        <div class="flex flex-col md:flex-row gap-10 items-center md:items-start">
          <!-- Thumbnail -->
          {post.data.thumbnail ? (
            <div class="w-full md:w-1/3 flex-shrink-0">
              <div class="rounded-2xl overflow-hidden shadow-lg border border-slate-100">
                <img src={post.data.thumbnail} alt={post.data.title} class="w-full h-auto object-cover" />
              </div>
            </div>
          ) : (
            <div class="w-full md:w-1/3 flex-shrink-0">
              <div class="rounded-2xl bg-slate-100 aspect-[3/4] flex items-center justify-center text-slate-300">
                 <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            </div>
          )}
          
          <!-- Details -->
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-[#0066FF]/10 text-[#0066FF] px-3 py-1 rounded-full font-medium text-sm">
                {post.data.category || 'Report'}
              </span>
              <span class="text-slate-400 text-sm font-medium">
                {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
            
            <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-6 leading-tight">
              {post.data.title}
            </h1>
            
            {post.data.description && (
              <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                {post.data.description}
              </p>
            )}
            
            {post.data.pdfUpload ? (
              <a href={post.data.pdfUpload} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-[#0066FF] hover:bg-[#0052CC] text-white px-8 py-4 rounded-xl font-medium transition-all shadow-lg shadow-[#0066FF]/20 hover:shadow-[#0066FF]/40 hover:-translate-y-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download Full Report
              </a>
            ) : (
              <a href="#contact-form" class="inline-flex items-center justify-center gap-2 bg-[#0066FF] hover:bg-[#0052CC] text-white px-8 py-4 rounded-xl font-medium transition-all shadow-lg shadow-[#0066FF]/20 hover:shadow-[#0066FF]/40 hover:-translate-y-0.5">
                Request Download
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-slate-100">
        <article class="prose prose-lg prose-slate max-w-none prose-a:text-[#0066FF] hover:prose-a:text-[#0052CC] prose-headings:text-slate-800 prose-img:rounded-2xl">
          <Content components={{ Callout, YouTube, CTA, a: MarkdownLink }} />
        </article>
      </div>
      
    </div>
  </div>
</Layout>
