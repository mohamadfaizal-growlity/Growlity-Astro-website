---
export const prerender = true;
import Layout from '../../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ArrowRight } from 'lucide-react';

export async function getStaticPaths({ paginate }: any) {
  const allPublications = await getCollection('publications', (post) => {
    return !post.data.draft; 
  });

  // Sort by date (newest first)
  allPublications.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

  // Get unique categories
  const uniqueCategories = [...new Set(allPublications.map((post) => post.data.category || 'Report'))];

  // Return paths for each category
  return uniqueCategories.flatMap((category) => {
    const categoryLower = category.toLowerCase().replace(/\s+/g, '-');
    const filteredPubs = allPublications.filter((post) => (post.data.category || 'Report') === category);
    
    return paginate(filteredPubs, {
      params: { category: categoryLower },
      props: { uniqueCategories, currentCategory: category },
      pageSize: 12,
    });
  });
}

const { page, uniqueCategories, currentCategory } = Astro.props as any;
---

<Layout title={`${currentCategory} | Growlity ${page.currentPage > 1 ? `| Page ${page.currentPage}` : ''}`}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-slate-800 mb-4">ESG Sustainability Publications</h1>
      <p class="text-xl text-slate-500">Global sustainability perspectives, reports, and insights.</p>
    </div>

    <div class="mb-10">
      <div class="flex overflow-x-auto pb-4 mb-2 sm:pb-0 sm:mb-6 sm:flex-wrap gap-3 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
        <a href="/esg-sustainability-publications" class="px-6 py-2 rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 font-medium text-sm transition-colors whitespace-nowrap shrink-0">All Publications</a>
        {uniqueCategories.map((category: string) => {
          const isActive = category === currentCategory;
          return (
            <a 
              href={`/esg-sustainability-publications/category/${category.toLowerCase().replace(/\s+/g, '-')}`} 
              class={`px-6 py-2 rounded-full font-medium text-sm transition-colors whitespace-nowrap shrink-0 ${isActive ? 'bg-[#0066FF] text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}
            >
              {category}
            </a>
          );
        })}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {page.data.map((post: any) => (
        <a href={`/esg-sustainability-publications/${post.id}`} class="block group">
          <article class="bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,102,255,0.06)] border border-slate-100 overflow-hidden hover:shadow-[0_8px_30px_rgb(0,102,255,0.12)] hover:-translate-y-1 transition-all duration-300 h-full flex flex-col">
            {post.data.featuredImage || post.data.thumbnail ? (
              <img 
                src={post.data.featuredImage || post.data.thumbnail} 
                alt={post.data.title} 
                class="w-full aspect-video object-cover"
              />
            ) : (
              <div class="w-full aspect-video bg-slate-50 flex items-center justify-center text-[#0066FF]/40 border-b border-slate-100">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center text-sm text-slate-500 mb-4">
                <span class="bg-[#0066FF]/10 text-[#0066FF] px-3 py-1 rounded-full font-medium text-xs">
                  {post.data.category || 'Report'}
                </span>
                <span class="mx-2 text-slate-300">•</span>
                <time datetime={post.data.publishDate.toISOString()} class="font-medium">
                  {post.data.publishDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="text-xl font-bold text-slate-800 group-hover:text-[#0066FF] transition-colors mb-3 leading-snug">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-slate-600 line-clamp-3 mt-auto leading-relaxed">
                  {post.data.description}
                </p>
              )}
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 mt-auto flex items-center text-[#0066FF] font-medium text-sm group-hover:bg-[#0066FF]/5 transition-colors">
              Read Report
              <svg class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </article>
        </a>
      ))}
    </div>

    {/* PAGINATION CONTROLS */}
    {page.lastPage > 1 && (
      <div class="mt-16 flex items-center justify-center gap-2">
        {page.url.prev ? (
          <a href={page.url.prev} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            <ArrowLeft className="w-4 h-4" /> Previous
          </span>
        )}
        
        <div class="flex items-center gap-1 mx-4">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
            <a 
              href={pageNum === 1 ? `/esg-sustainability-publications/category/${currentCategory.toLowerCase().replace(/\s+/g, '-')}` : `/esg-sustainability-publications/category/${currentCategory.toLowerCase().replace(/\s+/g, '-')}/${pageNum}`}
              class={`w-10 h-10 flex items-center justify-center rounded-lg font-medium transition-colors ${
                pageNum === page.currentPage 
                  ? 'bg-[#0066FF] text-white shadow-md' 
                  : 'text-slate-600 hover:bg-slate-100'
              }`}
            >
              {pageNum}
            </a>
          ))}
        </div>

        {page.url.next ? (
          <a href={page.url.next} class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:border-[#0066FF] hover:text-[#0066FF] hover:bg-blue-50 transition-colors font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </a>
        ) : (
          <span class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-100 text-slate-300 cursor-not-allowed font-medium">
            Next <ArrowRight className="w-4 h-4" />
          </span>
        )}
      </div>
    )}
  </main>
</Layout>
