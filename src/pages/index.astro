---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';

// In a real Sitepins setup, you would fetch from Astro content collections here:
// import { getCollection } from 'astro:content';
// const pages = await getCollection('pages');
// const homeData = pages.find(p => p.id === 'home');
---

<Layout title="Growlity | Business Sustainability Ratings">
  <Header />
  
  <main class="flex-grow">
    <Hero 
      heading="Business Sustainability Ratings"
      subheading="The world's most trusted business sustainability ratings. Manage ESG risk and compliance, meet corporate sustainability goals, and drive impact at scale."
      primaryCta="Get Rated"
      secondaryCta="Explore Network"
    />

    <!-- Quick Features Section -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-extrabold text-brand-dark sm:text-4xl">
            Why choose Growlity?
          </h2>
          <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
            Comprehensive sustainability intelligence for your entire value chain.
          </p>
        </div>

        <div class="mt-20">
          <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-3">
            
            <div class="flex flex-col text-center">
              <div class="flex items-center justify-center h-16 w-16 rounded-md bg-brand-light-green text-brand-green mx-auto">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="mt-6 text-xl font-bold text-brand-dark">Reduce Risk</h3>
              <p class="mt-2 text-base text-gray-500">
                Identify and mitigate ESG risks across your supply chain before they become issues.
              </p>
            </div>

            <div class="flex flex-col text-center">
              <div class="flex items-center justify-center h-16 w-16 rounded-md bg-brand-light-green text-brand-green mx-auto">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="mt-6 text-xl font-bold text-brand-dark">Drive Performance</h3>
              <p class="mt-2 text-base text-gray-500">
                Actionable scorecards and improvement plans to enhance your sustainability performance.
              </p>
            </div>

            <div class="flex flex-col text-center">
              <div class="flex items-center justify-center h-16 w-16 rounded-md bg-brand-light-green text-brand-green mx-auto">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              </div>
              <h3 class="mt-6 text-xl font-bold text-brand-dark">Global Reach</h3>
              <p class="mt-2 text-base text-gray-500">
                Assessments available in 180+ countries and multiple languages for your entire network.
              </p>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-brand-dark py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center text-white">
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 text-brand-green" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
          </svg>
          <span class="font-bold text-xl">Growlity</span>
        </div>
        <div class="text-gray-400 text-sm">
          &copy; {new Date().getFullYear()} Growlity. All rights reserved.
        </div>
      </div>
    </div>
  </footer>
</Layout>

