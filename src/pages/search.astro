---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/shared/SearchBar.astro';
---

<Layout title="Search | Growlity">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Search</h1>
      <p class="text-xl text-gray-600">Find insights, solutions, and case studies.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
      <SearchBar />
    </div>
  </main>
</Layout>

