---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWebinars = await getCollection('webinars');

// Sort by date
allWebinars.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Webinars | Growlity">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-slate-800 mb-4">Webinars & Events</h1>
      <p class="text-xl text-slate-500">Join our experts to navigate the future of sustainability.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allWebinars.map((post) => (
        <a href={`/webinars/${post.id}`} class="block group">
          <article class="bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,102,255,0.06)] border border-slate-100 overflow-hidden hover:shadow-[0_8px_30px_rgb(0,102,255,0.12)] hover:-translate-y-1 transition-all duration-300 h-full flex flex-col relative">
            
            {post.data.upcomingToggle && (
              <div class="absolute top-4 right-4 bg-[#00C853] text-white text-xs font-bold px-3 py-1.5 rounded-full z-10 shadow-lg shadow-[#00C853]/30">
                UPCOMING
              </div>
            )}
            
            {post.data.featuredImage || post.data.banner ? (
              <img 
                src={post.data.featuredImage || post.data.banner} 
                alt={post.data.title} 
                class="w-full h-48 object-cover"
              />
            ) : (
              <div class="w-full h-48 bg-slate-50 flex items-center justify-center text-[#0066FF]/30">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center text-sm text-slate-500 mb-3 font-medium">
                <svg class="w-4 h-4 mr-1.5 text-[#0066FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="text-xl font-bold text-slate-800 group-hover:text-[#0066FF] transition-colors mb-4 leading-snug">
                {post.data.title}
              </h2>
              
              {post.data.speaker && (
                <div class="mt-auto flex items-center gap-3 pt-4 border-t border-slate-100">
                  <div class="w-8 h-8 rounded-full bg-[#0066FF]/10 flex items-center justify-center text-[#0066FF] font-bold text-sm">
                    {post.data.speaker.charAt(0)}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-slate-700">{post.data.speaker}</p>
                    <p class="text-xs text-slate-500">Speaker</p>
                  </div>
                </div>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>
</Layout>
